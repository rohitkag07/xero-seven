# ============================================================
# Xero Seven — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ---- InsForge Backend (required) ----
# Your InsForge project base URL.
# Find this in: InsForge Dashboard → Project → Settings → API
VITE_INSFORGE_URL=https://your-project.us-east.insforge.app

# InsForge anonymous key (required for database/storage/auth operations).
# Find this in: InsForge Dashboard → Project → Settings → API Keys
VITE_INSFORGE_ANON_KEY=ik_your_anon_key_here

# ---- Optional: Vercel deployment (set in Vercel dashboard, not here) ----
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id
